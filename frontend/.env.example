# ─── Backend proxy URL ────────────────────────────────────────────────────────
# Used by Next.js server-side rewrites to proxy /api/* → backend
BACKEND_URL=http://localhost:8000

# ─── Public API URL (browser-side fetch calls) ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
