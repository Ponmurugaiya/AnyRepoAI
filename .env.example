# ─── Application ──────────────────────────────────────────────────────────────
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:3000

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=codebase_intel
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_in_production

# ─── Repository Management ────────────────────────────────────────────────────
REPO_CLONE_ROOT=/storage/repos
REPO_CLONE_TIMEOUT=300
REPO_MAX_REPO_SIZE_MB=2048
REPO_GITHUB_API_BASE_URL=https://api.github.com
# Optional: GitHub Personal Access Token for private repos and higher rate limits
REPO_GITHUB_TOKEN=
